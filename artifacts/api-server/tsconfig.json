{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "composite": false,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "paths": {
      "@workspace/db": ["../../lib/db/src/index.ts"],
      "@workspace/api-zod": ["../../lib/api-zod/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../../lib/db" },
    { "path": "../../lib/api-zod" }
  ]
}
